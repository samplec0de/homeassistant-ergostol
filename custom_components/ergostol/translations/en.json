{
  "config": {
    "flow_title": "{name}",
    "step": {
      "confirm": {
        "description": "Add Ergostol desk {name}?"
      },
      "user": {
        "description": "Select the Ergostol desk to add.",
        "data": {
          "address": "Device"
        }
      }
    },
    "abort": {
      "already_configured": "This desk is already configured",
      "no_devices_found": "No Ergostol desks found. Make sure the desk's Bluetooth adapter is powered and in range of Home Assistant."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Ergostol Desk options",
        "description": "Preset heights drive the Sit/Stand buttons. Quiet hours pause background polling so the desk's LED panel stays dark (e.g. overnight) — explicit moves still work; leave both times empty to poll around the clock.",
        "data": {
          "sit_height": "Sit preset height (cm)",
          "stand_height": "Stand preset height (cm)",
          "quiet_start": "Quiet hours start",
          "quiet_end": "Quiet hours end"
        }
      }
    }
  },
  "entity": {
    "number": {
      "height": { "name": "Height" }
    },
    "sensor": {
      "current_height": { "name": "Current height" },
      "desk_error": {
        "name": "Fault",
        "state": {
          "none": "None",
          "e01": "E01 — motor stop",
          "e02": "E02 — desynchronised",
          "e03": "E03 — cable",
          "e04": "E04 — communication",
          "e05": "E05 — overload",
          "hot": "Overheated",
          "unknown": "Unknown"
        }
      }
    },
    "binary_sensor": {
      "moving": { "name": "Moving" }
    },
    "button": {
      "stop": { "name": "Stop" },
      "preset_sit": { "name": "Sit preset" },
      "preset_stand": { "name": "Stand preset" }
    }
  }
}
